	for z in range(maze.size()):
		for x in range(maze[z].size()):
			if maze[z][x] == 1:
				set_cell_item(Vector3i(x, 0, z), 0, 0)

func _create_default_library():
	# Create a simple MeshLibrary procedurally
	var lib = MeshLibrary.new()
	
	# Create a simple box mesh for the wall
	var box = BoxMesh.new()
	box.size = Vector3(1, 3, 1)
	
	# Create a material
	var mat = StandardMaterial3D.new()
	mat.albedo_color = Color(0.3, 0.3, 0.3)
	box.material = mat
	
	# Create a collision shape
	var shape = BoxShape3D.new()
	shape.size = Vector3(1, 3, 1)
	
	# Add to library
	lib.create_item(0)
	lib.set_item_mesh(0, box)
	lib.set_item_shape(0, shape)
	
	mesh_library = lib
